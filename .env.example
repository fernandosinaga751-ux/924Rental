# ============================================================
# COPY FILE INI → .env  (jangan hapus file .env.example ini)
# Isi dengan konfigurasi Firebase project kamu
# ============================================================

# Ambil dari: Firebase Console → Project Settings → Your Apps → Web App
VITE_FIREBASE_API_KEY=AIzaSy_ISI_DISINI
VITE_FIREBASE_AUTH_DOMAIN=nama-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=nama-project
VITE_FIREBASE_STORAGE_BUCKET=nama-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef123456

# ============================================================
# Cara pakai:
# 1. cp .env.example .env
# 2. Isi nilai di atas dengan data dari Firebase Console
# 3. Pastikan .env ada di .gitignore (sudah ada)
# 4. Di Vercel: Settings → Environment Variables → tambahkan semua baris di atas
# ============================================================
