rules_version = '2';

// ============================================================
// Firestore Security Rules — Dearma Rental Mobil Medan
// Upload file ini ke: Firebase Console → Firestore → Rules
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // Koleksi publik: siapa pun boleh BACA (untuk tampilan website)
    // Hanya admin (terautentikasi) yang boleh TULIS

    match /cars/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /articles/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Config (settings & seo) — hanya admin
    match /config/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Semua koleksi lain: tolak akses
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
